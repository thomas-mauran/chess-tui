Require echo

Set BorderRadius 10
Set Shell zsh

Set FontSize 14
Set Width 2000
Set Height 1300

Set WindowBar Colorful
Set WindowBarSize 40

Type "cargo run -- --no-sound --depth 10 --difficulty hard --skin Default" Sleep 100ms  Enter

Sleep 1.5s
Down @0.3s
Down @0.3s
Down @0.3s
Down @0.3s
Space @0.3s
Sleep 0.8s

Type h

Sleep 4s
